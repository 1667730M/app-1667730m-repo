pipeline {
    agent any

    environment {
        POLITE_ID = "1667730m"
        UAT_PORT = "33100"
        WORK_DIR = "/tmp/work/1667730m"
    }

    stages {

        stage("Stage 1 - Preparation Check") {
            steps {
                echo "stg1_${POLITE_ID}: Preparation check passes"
            }
        }

        stage("Stage 2 - UAT Web Test") {
            steps {
                sh '''
                echo "Running web test..."

                curl -Is http://localhost:${UAT_PORT} | head -n 1 > /tmp/testsvr-result-file

                cat /tmp/testsvr-result-file

                if grep -q "HTTP/1.1 200" /tmp/testsvr-result-file; then
                    echo "stg2_${POLITE_ID}: testsvr's website is running"
                else
                    echo "stg2_${POLITE_ID}: testsvr's website is down"
                    exit 1
                fi
                '''

                // Prompt user only if previous check passed
                input message: "Proceed to update testsvr server?", ok: "Proceed"
            }
        }
        stage("Stage 3 - Backup and Update testsvr") {
            steps {
                sh """
                echo "stg3_${POLITE_ID}: Starting backup and update process"

                # Remove old backup image if exists
                docker image rm -f testsvr_image || true

                # Create new backup image for testsvr
                docker commit testsvr_1667730m testsvr_image

                echo "Backup image testsvr_image created"


                # Clean previous work directory
                puppet resource file ${WORK_DIR} ensure=absent force=true;

                # Recreate work directory
                puppet resource file ${WORK_DIR} ensure=directory;

                # Move into work directory
                cd ${WORK_DIR};

                # Clone repository
                git clone https://github.com/1667730M/app-1667730m-repo.git;

                echo "stg3_${POLITE_ID}: testsvr is backup and updated"


                """
            }
        }
    }
}